# Copy to .env and fill in secrets. Local compose defaults match Postgres/MinIO below.
# Email is Resend (external API) — not provided by docker compose.

# --- Postgres (docker compose: postgres) ---
# User / password / db: alma / alma / alma
DATABASE_URL=postgresql://alma:alma@localhost:5432/alma
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=alma
POSTGRES_PASSWORD=alma
POSTGRES_DB=alma

# --- MinIO / S3-compatible object storage (docker compose: minio) ---
# API: http://localhost:9000  Console: http://localhost:9001
# Root user/password (local only): minioadmin / minioadmin
# Default bucket created by minio-init: lead-files (lead uploads; resumes today)
S3_ENDPOINT=http://localhost:9000
# Browser-facing endpoint for presigned resume URLs. Docker Compose sets this to
# http://localhost:9000 while the API talks to MinIO at http://minio:9000.
S3_PUBLIC_ENDPOINT=
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lead-files
S3_REGION=us-east-1
# Set true for MinIO / path-style S3-compatible endpoints
S3_FORCE_PATH_STYLE=true

# --- Resend (external; no local mail container) ---
# https://resend.com — create an API key and verified sender domain/address
# Templates are Resend-hosted (dashboard); template ids are hardcoded in the backend.
# If ATTORNEY_NOTIFY_EMAIL is empty, the attorney new-lead email is skipped.
RESEND_API_KEY=
FROM_EMAIL=alma@resend.kylediaz.com
ATTORNEY_NOTIFY_EMAIL=

# --- Public web origin (used in attorney notification dashboard links) ---
PUBLIC_URL=http://localhost:3000

# --- Session cookie (server-side sessions in Postgres) ---
SESSION_COOKIE_NAME=session_id
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_SECONDS=604800

# --- CORS (Next.js local) ---
CORS_ORIGINS=http://localhost:3000

# --- Resume upload limits ---
# App enforces this in-process; production should also enforce at the reverse proxy.
RESUME_MAX_BYTES=5242880

