# Copy to .env and fill in secrets. Local compose defaults match Postgres/MinIO below.
# Email is Resend (external API) — not provided by docker compose.

# --- Postgres (docker compose: postgres) ---
# User / password / db: alma / alma / alma
DATABASE_URL=postgresql://alma:alma@localhost:5432/alma
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=alma
POSTGRES_PASSWORD=alma
POSTGRES_DB=alma

# --- MinIO / S3-compatible object storage (docker compose: minio) ---
# API: http://localhost:9000  Console: http://localhost:9001
# Root user/password (local only): minioadmin / minioadmin
# Default bucket created by minio-init: lead-files (lead uploads; resumes today)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lead-files
S3_REGION=us-east-1
# Set true for MinIO / path-style S3-compatible endpoints
S3_FORCE_PATH_STYLE=true

# --- Resend (external; no local mail container) ---
# https://resend.com — create an API key and verified sender domain/address
# Templates are Resend-hosted (dashboard); backend sends template id + variables.
# Required template variables: see docs/DESIGN.md (Email templating).
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev
ATTORNEY_NOTIFY_EMAIL=
RESEND_TEMPLATE_PROSPECT_CONFIRMATION=
RESEND_TEMPLATE_ATTORNEY_NEW_LEAD=
